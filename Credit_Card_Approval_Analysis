        "# initialize lasso pipeline (optimizing l1 penalty for roc_auc - better for model comparison)\n",
        "lasso_log_reg = Pipeline([\n",
        "    ('scaler', StandardScaler()),\n",
        "    ('model', LogisticRegressionCV(\n",
        "        penalty='l1',\n",
        "        solver='saga',\n",
        "        cv=5,\n",
        "        scoring='roc_auc',\n",
        "        max_iter=5000\n",
        "    ))\n",
        "])\n",
        "\n",
        "# fit the model\n",
        "lasso_log_reg.fit(X_logreg_train, y_train)\n",
        "\n",
        "# getting coefficents for the features\n",
        "coeffs = lasso_log_reg.named_steps['model'].coef_[0]\n",
        "features = X_logreg_train.columns\n",
