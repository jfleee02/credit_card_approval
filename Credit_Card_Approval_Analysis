        "# initialize pipeline\n",
        "svm_linear = Pipeline([\n",
        "    (\"scaler\", StandardScaler()),\n",
        "    (\"model\", LinearSVC(max_iter=20000, random_state=42))\n",
        "])\n",
        "\n",
        "# paramters to random search\n",
        "param_dist_linear = {\n",
        "    # C controls the margin/regularization strength:\n",
        "    # small C = more regularization (simpler boundary)\n",
        "    # large C = less regularization (more complex boundary)\n",
        "    \"model__C\": np.logspace(-3, 2, 10),\n",
        "\n",
        "    # balanced can help if classes are imbalanced\n",
        "    \"model__class_weight\": [None, \"balanced\"]\n",
        "}\n",
        "\n",
        "# random search\n",
        "search_linear = RandomizedSearchCV(\n",
        "    estimator=svm_linear,\n",
        "    param_distributions=param_dist_linear,\n",
        "    n_iter=15,                # keep small for speed\n",
        "    scoring=\"roc_auc\",        # threshold-independent tuning\n",
        "    cv=5,\n",
        "    n_jobs=-1,\n",
        "    random_state=42,\n",
        "    verbose=1\n",
        ")\n",
        "\n",
        "# displaying the best results\n",
        "search_linear.fit(X_train, y_train)\n",
        "best_svm_linear = search_linear.best_estimator_\n",
        "print(\"Best Params:\", search_linear.best_params_)\n",
