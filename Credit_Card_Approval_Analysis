        "def _get_scores(model, X):\n",
        "    \"\"\"\n",
        "    Return a 1D array of model scores for the positive class.\n",
        "\n",
        "    Prefers:\n",
        "      - predict_proba(X)[:, 1]  (probabilities)\n",
        "    Falls back to:\n",
        "      - decision_function(X)    (signed scores)\n",
        "\n",
        "    Raises if neither exists.\n",
        "    \"\"\"\n",
        "    if hasattr(model, \"predict_proba\"):\n",
        "        return model.predict_proba(X)[:, 1]\n",
        "    if hasattr(model, \"decision_function\"):\n",
        "        return model.decision_function(X)\n",
        "    raise ValueError(\"Model must support predict_proba() or decision_function().\")\n",
        "\n",
        "\n",
        "def _best_threshold_by_fbeta(scores, y_true, beta=2.0, grid_size=1001):\n",
        "    \"\"\"\n",
        "    Choose the threshold that maximizes F-beta on provided scores/labels.\n",
        "\n",
        "    F-beta weights recall more than precision when beta > 1.\n",
        "      - beta = 1   -> F1\n",
        "      - beta = 2   -> recall is weighted more heavily (common in \"capture positives\" settings)\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    scores : array-like, shape (n_samples,)\n",
        "        Probability/scores for the positive class.\n",
        "    y_true : array-like, shape (n_samples,)\n",
        "        True labels encoded as 0/1 (positive class = 1).\n",
        "    beta : float\n",
        "        F-beta parameter.\n",
        "    grid_size : int\n",
        "        Number of threshold candidates (quantile grid).\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    best_threshold : float\n",
        "    best_fbeta : float\n",
        "    \"\"\"\n",
        "    scores = np.asarray(scores)\n",
        "    y_true = np.asarray(y_true).astype(int)\n",
        "\n",
        "    # Candidate thresholds via score quantiles (robust + efficient)\n",
        "    qs = np.linspace(0, 1, grid_size)\n",
        "    thresholds = np.unique(np.quantile(scores, qs))\n",
        "\n",
        "    b2 = beta ** 2\n",
        "    best_t = float(thresholds[0])\n",
        "    best_score = -np.inf\n",
        "\n",
        "    for t in thresholds:\n",
        "        y_hat = (scores >= t).astype(int)\n",
        "        tn, fp, fn, tp = confusion_matrix(y_true, y_hat, labels=[0, 1]).ravel()\n",
        "\n",
        "        # Precision / Recall with safe handling for 0-division\n",
        "        p = tp / (tp + fp) if (tp + fp) > 0 else 0.0\n",
        "        r = tp / (tp + fn) if (tp + fn) > 0 else 0.0\n",
        "\n",
        "        denom = (b2 * p + r)\n",
        "        fbeta = ((1 + b2) * p * r / denom) if denom > 0 else 0.0\n",
        "\n",
        "        if fbeta > best_score:\n",
        "            best_score = fbeta\n",
        "            best_t = float(t)\n",
        "\n",
        "    return best_t, float(best_score)\n",
        "\n",
        "\n",
        "def add_model_row_with_cv_threshold_fbeta(\n",
        "    model_metrics: pd.DataFrame,\n",
        "    model,\n",
        "    X_train,\n",
        "    y_train,\n",
        "    X_test,\n",
        "    y_test,\n",
        "    model_name: str = None,\n",
        "    *,\n",
        "    beta: float = 2.0,\n",
        "    cv_splits: int = 5,\n",
        "    random_state: int = 42,\n",
        "    threshold_grid_size: int = 1001,\n",
        "    positive_label: int = 1,\n",
        "    zero_division: int = 0,\n",
        "):\n",
        "    \"\"\"\n",
        "    Fit a model, tune a probability/score threshold using CV on the TRAIN set\n",
        "    by maximizing F-beta, then evaluate TEST metrics using that fixed threshold.\n",
        "\n",
        "    What gets appended (1 row):\n",
        "      - Model\n",
        "      - Optimal Threshold (CV)\n",
        "      - Optimal Fβ (CV)\n",
        "      - Test Accuracy / Precision / Recall / F1 (threshold-dependent using optimal threshold)\n",
        "      - Test ROC-AUC (threshold-independent; uses continuous test scores)\n",
        "\n",
        "    Why this is correct:\n",
        "      - Threshold is tuned ONLY on training data via out-of-fold predictions.\n",
        "      - Test set remains untouched until final evaluation (no leakage).\n",
        "\n",
        "    Notes:\n",
        "      - beta > 1 prioritizes recall (catch positives).\n",
        "      - beta < 1 prioritizes precision (avoid false positives).\n",
        "    \"\"\"\n",
        "\n",
        "    # ---------------------------\n",
        "    # Model name\n",
        "    # ---------------------------\n",
        "    if model_name is None:\n",
        "        model_name = model.__class__.__name__\n",
        "\n",
        "    # ---------------------------\n",
        "    # 1) Cross-validated out-of-fold (OOF) scores on TRAIN\n",
        "    # ---------------------------\n",
        "    skf = StratifiedKFold(n_splits=cv_splits, shuffle=True, random_state=random_state)\n",
        "\n",
        "    oof_scores = np.empty(len(y_train), dtype=float)\n",
        "\n",
        "    for train_idx, val_idx in skf.split(X_train, y_train):\n",
        "        m = clone(model)\n",
        "\n",
        "        # pandas-safe indexing\n",
        "        X_tr = X_train.iloc[train_idx] if hasattr(X_train, \"iloc\") else X_train[train_idx]\n",
        "        y_tr = y_train.iloc[train_idx] if hasattr(y_train, \"iloc\") else y_train[train_idx]\n",
        "        X_val = X_train.iloc[val_idx] if hasattr(X_train, \"iloc\") else X_train[val_idx]\n",
        "\n",
        "        m.fit(X_tr, y_tr)\n",
        "        oof_scores[val_idx] = _get_scores(m, X_val)\n",
        "\n",
        "    # Ensure labels are 0/1 with positive_label mapped to 1\n",
        "    y_train_bin = (np.asarray(y_train) == positive_label).astype(int)\n",
        "\n",
        "    # ---------------------------\n",
        "    # 2) Find optimal threshold on OOF scores (TRAIN only)\n",
        "    # ---------------------------\n",
        "    best_thr, best_fbeta = _best_threshold_by_fbeta(\n",
        "        oof_scores, y_train_bin,\n",
        "        beta=beta,\n",
        "        grid_size=threshold_grid_size\n",
        "    )\n",
        "\n",
        "    # ---------------------------\n",
        "    # 3) Fit final model on FULL TRAIN\n",
        "    # ---------------------------\n",
        "    final_model = clone(model)\n",
        "    final_model.fit(X_train, y_train)\n",
        "\n",
        "    # ---------------------------\n",
        "    # 4) Evaluate on TEST using fixed threshold\n",
        "    # ---------------------------\n",
        "    test_scores = _get_scores(final_model, X_test)\n",
        "    y_test_bin = (np.asarray(y_test) == positive_label).astype(int)\n",
        "\n",
        "    y_pred_test = (test_scores >= best_thr).astype(int)\n",
        "\n",
        "    acc = accuracy_score(y_test_bin, y_pred_test)\n",
        "    prec = precision_score(y_test_bin, y_pred_test, pos_label=1, zero_division=zero_division)\n",
        "    rec = recall_score(y_test_bin, y_pred_test, pos_label=1)\n",
        "    f1 = f1_score(y_test_bin, y_pred_test, pos_label=1)\n",
        "    auc = roc_auc_score(y_test_bin, test_scores)\n",
        "\n",
        "    # test values\n",
        "    b2 = beta ** 2\n",
        "    denom = (b2 * prec + rec)\n",
        "    test_fbeta = ((1 + b2) * prec * rec / denom) if denom > 0 else 0.0\n",
        "\n",
        "    # ---------------------------\n",
        "    # 5) Append row\n",
        "    # ---------------------------\n",
        "    new_row = pd.DataFrame([{\n",
        "        \"Model\": model_name,\n",
        "        \"Optimal Threshold (CV)\": best_thr,\n",
        "        \"Optimal Fβ (CV)\": best_fbeta,\n",
        "        \"beta\": beta,\n",
        "        \"Test Accuracy\": acc,\n",
        "        \"Test Precision\": prec,\n",
        "        \"Test Recall\": rec,\n",
        "        \"Test F1\": f1,\n",
        "        \"Test ROC-AUC\": auc,\n",
        "        \"Test Fβ\": test_fbeta\n",
        "    }])\n",
        "\n",
        "    if model_metrics is None or model_metrics.empty:\n",
        "        return new_row\n",
        "\n",
        "    return pd.concat([model_metrics, new_row], ignore_index=True)"
      ],
