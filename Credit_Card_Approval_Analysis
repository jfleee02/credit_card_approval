      "source": [
        "def p_val_sklearn_l2(pipeline, X):\n",
        "    \"\"\"\n",
        "    Compute approximate (Wald) p-values for a scikit-learn LogisticRegression\n",
        "    that is inside a Pipeline with a StandardScaler.\n",
        "\n",
        "    IMPORTANT CONTEXT\n",
        "    -----------------\n",
        "    - scikit-learn's LogisticRegression is *regularized by default* (L2 penalty).\n",
        "      That means the classic unpenalized covariance formula (X' W X)^(-1) does NOT\n",
        "      match the model you fit.\n",
        "    - To make the standard-error / p-value approximation align better with the\n",
        "      fitted model, we add the L2 penalty term to the Fisher information:\n",
        "            Fisher_penalized = X' W X + λ I\n",
        "      where λ = 1/C in sklearn (roughly), and we do NOT penalize the intercept.\n",
        "\n",
        "    WHAT YOU GET\n",
        "    ------------\n",
        "    - This returns p-values for [intercept, feature_1, feature_2, ... feature_p]\n",
        "      in the SAME ORDER.\n",
        "\n",
        "    LIMITATIONS\n",
        "    -----------\n",
        "    - These are *approximate* Wald p-values.\n",
        "    - Regularization changes the inference story; these are not \"textbook\" p-values.\n",
        "    - If you need strict inference, use statsmodels.Logit instead.\n",
        "    \"\"\"\n",
        "\n",
        "    # ------------------------------------------------------------\n",
        "    # 1) Pull out the fitted scaler + fitted logistic regression model\n",
        "    # ------------------------------------------------------------\n",
        "    scaler = pipeline.named_steps['scaler']\n",
        "    clf = pipeline.named_steps['model']  # this is sklearn.linear_model.LogisticRegression\n",
        "\n",
        "    # ------------------------------------------------------------\n",
        "    # 2) Transform X using the *already-fitted* scaler in the pipeline\n",
        "    #    (Do NOT fit a new StandardScaler here, or you'll mismatch the model.)\n",
        "    # ------------------------------------------------------------\n",
        "    X_scaled = scaler.transform(X)  # shape: (n_samples, n_features)\n",
        "\n",
        "    # ------------------------------------------------------------\n",
        "    # 3) Build the design matrix with an intercept column.\n",
        "    #    Logistic regression includes an intercept by default in sklearn.\n",
        "    #    Adding a column of 1s makes matrix math align with beta = [b0, b1, ..., bp]\n",
        "    # ------------------------------------------------------------\n",
        "    n = X_scaled.shape[0]\n",
        "    X_design = np.hstack([np.ones((n, 1)), X_scaled])  # shape: (n_samples, p+1)\n",
        "\n",
        "    # ------------------------------------------------------------\n",
        "    # 4) Get predicted probabilities p_i = P(y=1 | x_i)\n",
        "    #    Using the pipeline ensures scaling is applied consistently.\n",
        "    # ------------------------------------------------------------\n",
        "    p = pipeline.predict_proba(X)[:, 1]  # shape: (n_samples,)\n",
        "\n",
        "    # ------------------------------------------------------------\n",
        "    # 5) For logistic regression, the \"weights\" in the Hessian/Fisher matrix are:\n",
        "    #       w_i = p_i * (1 - p_i)\n",
        "    #    These capture the variance of each Bernoulli prediction.\n",
        "    # ------------------------------------------------------------\n",
        "    w = p * (1 - p)  # shape: (n_samples,)\n",
        "\n",
        "    # ------------------------------------------------------------\n",
        "    # 6) Compute Fisher information (approx. Hessian):\n",
        "    #       Fisher = X' W X\n",
        "    #    where W is a diagonal matrix with w_i on the diagonal.\n",
        "    #\n",
        "    #    We avoid constructing the huge diagonal matrix W explicitly.\n",
        "    #    Instead, we multiply each row of X_design by w_i:\n",
        "    #       XW = W X  <== implemented as elementwise scaling of rows\n",
        "    # ------------------------------------------------------------\n",
        "    XW = X_design * w[:, None]      # shape: (n_samples, p+1)\n",
        "    fisher = X_design.T @ XW        # shape: (p+1, p+1)\n",
        "\n",
        "    # ------------------------------------------------------------\n",
        "    # 7) Account for L2 regularization (default behavior in sklearn).\n",
        "    #\n",
        "    #    sklearn uses penalty=\"l2\" by default, with strength controlled by C.\n",
        "    #    Larger C -> weaker penalty, smaller C -> stronger penalty.\n",
        "    #\n",
        "    #    A common approximation for penalized Hessian is:\n",
        "    #       Fisher_penalized = X' W X + λ I\n",
        "    #    with λ = 1/C\n",
        "    #\n",
        "    #    NOTE: The intercept is not penalized, so the first diagonal stays 0.\n",
        "    # ------------------------------------------------------------\n",
        "    lam = 1.0 / clf.C\n",
        "    reg = np.diag([0] + [lam] * (X_design.shape[1] - 1))  # (p+1, p+1)\n",
        "    fisher = fisher + reg\n",
        "\n",
        "    # ------------------------------------------------------------\n",
        "    # 8) Invert Fisher to get an approximate covariance matrix:\n",
        "    #       cov ≈ (Fisher_penalized)^(-1)\n",
        "    #\n",
        "    #    We use pseudo-inverse (pinv) instead of inv for numerical stability.\n",
        "    #    If Fisher is close to singular, inv can explode; pinv is safer.\n",
        "    # ------------------------------------------------------------\n",
        "    cov = np.linalg.pinv(fisher)\n",
        "\n",
        "    # ------------------------------------------------------------\n",
        "    # 9) Standard errors are the square roots of the diagonal of cov.\n",
        "    #    Due to floating point issues, the diagonal can have tiny negatives\n",
        "    #    (e.g., -1e-15). We clip at 0 before sqrt to avoid invalid values.\n",
        "    # ------------------------------------------------------------\n",
        "    var = np.diag(cov)  # variances for [intercept, coefficients...]\n",
        "    se = np.sqrt(np.clip(var, 0, np.inf))\n",
        "\n",
        "    # ------------------------------------------------------------\n",
        "    # 10) Build the full coefficient vector beta matching X_design:\n",
        "    #     beta = [intercept, coef_1, ..., coef_p]\n",
        "    # ------------------------------------------------------------\n",
        "    beta = np.concatenate([clf.intercept_, clf.coef_[0]])  # shape: (p+1,)\n",
        "\n",
        "    # ------------------------------------------------------------\n",
        "    # 11) Wald z-scores:\n",
        "    #       z_j = beta_j / se_j\n",
        "    #\n",
        "    #     If se_j is 0 (can happen in degenerate cases), we avoid divide-by-zero\n",
        "    #     by returning NaN for that z-score.\n",
        "    # ------------------------------------------------------------\n",
        "    z = np.divide(beta, se, out=np.full_like(beta, np.nan, dtype=float), where=se > 0)\n",
        "\n",
        "    # ------------------------------------------------------------\n",
        "    # 12) Two-sided p-values from standard normal:\n",
        "    #       pval_j = 2 * (1 - Phi(|z_j|))\n",
        "    # ------------------------------------------------------------\n",
        "    pvals = 2 * (1 - stats.norm.cdf(np.abs(z)))\n",
        "\n",
        "    return pvals"
      ],
