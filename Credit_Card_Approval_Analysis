    {
      "cell_type": "code",
      "source": [
        "X_cols = [\n",
        "    \"Debt\",\"Income_log\",\"YearsEmployed\",\"PriorDefault\",\"BankCustomer\",\"Employed\",\n",
        "    \"CreditScore_Low\",\"CreditScore_Moderate\",\"CreditScore_High\",\"Ethnicity_Latino\"\n",
        "]\n",
        "y_col = \"Approved\"\n",
        "\n",
        "tmp = df[X_cols + [y_col]].copy()\n",
        "\n",
        "# Convert bool -> int (THIS is the key fix)\n",
        "bool_cols = tmp.select_dtypes(include=[\"bool\"]).columns\n",
        "tmp[bool_cols] = tmp[bool_cols].astype(int)\n",
        "\n",
        "# Safety: remove inf / missing\n",
        "tmp = tmp.replace([np.inf, -np.inf], np.nan).dropna()\n",
        "\n",
        "X = sm.add_constant(tmp[X_cols], has_constant=\"add\")\n",
        "y = tmp[y_col].astype(int)\n",
        "\n",
        "model = sm.Logit(y, X).fit(disp=False)\n",
        "print(model.summary())\n",
        "\n",
        "# Focused readout for Ethnicity_Latino\n",
        "coef = model.params[\"Ethnicity_Latino\"]\n",
        "se   = model.bse[\"Ethnicity_Latino\"]\n",
        "pval = model.pvalues[\"Ethnicity_Latino\"]\n",
        "OR   = np.exp(coef)\n",
        "CI   = np.exp([coef - 1.96*se, coef + 1.96*se])\n",
        "\n",
        "print(\"\\nEthnicity_Latino (controlled) effect:\")\n",
        "print(f\"coef={coef:.4f}, OR={OR:.4f}, p={pval:.4g}, OR 95% CI=[{CI[0]:.4f}, {CI[1]:.4f}]\")\n",
        "print(f\"Rows used: {len(tmp)}\")"
