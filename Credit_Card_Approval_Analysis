        "# 1) Base column lists\n",
        "# ----------------------------\n",
        "\n",
        "# numeric columns (exclude target and binary)\n",
        "num_cols_all = crd_dta_org.select_dtypes(include=\"number\").columns\n",
        "num_cols = [c for c in num_cols_all if c != target and crd_dta_org[c].nunique() > 2]\n",
        "\n",
        "# categorical columns (object/category)\n",
        "cat_cols = list(crd_dta_org.select_dtypes(include=[\"object\", \"category\"]).columns)\n",
        "\n",
        "# If ZipCode exists and is numeric, treat it as categorical for plots\n",
        "if \"ZipCode\" in crd_dta_org.columns and pd.api.types.is_numeric_dtype(crd_dta_org[\"ZipCode\"]):\n",
        "    if \"ZipCode\" not in cat_cols:\n",
        "        cat_cols = cat_cols + [\"ZipCode\"]\n",
        "\n",
        "# ----------------------------\n",
        "# 2) FILTERING RULES (EDA-only)\n",
        "# ----------------------------\n",
        "\n",
        "# (A) Keep numeric vars that correlate with Approved above a threshold\n",
        "corr_thresh = 0.10  # tune: 0.10 exploratory, 0.15 solid, 0.25 strong\n",
        "corr_target = (\n",
        "    crd_dta_org.select_dtypes(include=\"number\")\n",
        "    .corr(numeric_only=True)[target]\n",
        "    .drop(target, errors=\"ignore\")\n",
        "    .abs()\n",
        "    .sort_values(ascending=False)\n",
        ")\n",
        "\n",
        "important_num = [c for c in num_cols if corr_target.get(c, 0) >= corr_thresh]\n",
        "\n",
        "# fallback: if threshold too strict, keep top 5 numeric vars\n",
        "if len(important_num) == 0:\n",
        "    important_num = corr_target.index.tolist()[:5]\n",
        "    # remove binary + target just in case\n",
        "    important_num = [c for c in important_num if c in num_cols]\n",
        "\n",
        "print(\"Important numeric columns:\", important_num)\n",
        "\n",
        "\n",
        "# (B) Keep categorical vars with meaningful separation in approval rate\n",
        "sep_thresh = 0.10 # approval-rate range threshold (max-min)\n",
        "important_cat = []\n",
        "for col in cat_cols:\n",
        "    rates = crd_dta_org.groupby(col)[target].mean()\n",
        "    if (rates.max() - rates.min()) >= sep_thresh:\n",
        "        important_cat.append(col)\n",
        "\n",
        "# (C) Drop categorical vars with tiny groups (unstable rates)\n",
        "min_group_size = 5\n",
        "important_cat = [\n",
        "    c for c in important_cat\n",
        "    if crd_dta_org[c].value_counts().min() >= min_group_size\n",
        "]\n",
        "\n",
        "print(\"Important categorical columns:\", important_cat)\n",
        "\n",
        "\n",
        "# ----------------------------\n",
        "# 3) Plot function (same as yours)\n",
        "# ----------------------------\n",
        "\n",
        "def plot_numeric_by_categorical(crd_dta_org, cat_col, num_cols, max_levels=15, ncols=3):\n",
        "    # limit categories to top N by count to keep plots readable\n",
        "    if crd_dta_org[cat_col].nunique() > max_levels:\n",
        "        top = crd_dta_org[cat_col].value_counts().head(max_levels).index\n",
        "        d = crd_dta_org[crd_dta_org[cat_col].isin(top)].copy()\n",
        "    else:\n",
        "        d = crd_dta_org.copy()\n",
        "\n",
        "    nrows = math.ceil(len(num_cols) / ncols)\n",
        "    fig, axes = plt.subplots(nrows, ncols, figsize=(16, 4*nrows))\n",
        "    axes = np.array(axes).reshape(-1)  # flatten safely\n",
        "\n",
        "    for ax, num in zip(axes, num_cols):\n",
        "        sns.boxplot(data=d, x=cat_col, y=num, ax=ax)\n",
        "        ax.set_title(f\"{num} by {cat_col}\")\n",
        "        ax.tick_params(axis=\"x\", rotation=45 if d[cat_col].nunique() > 5 else 0)\n",
        "\n",
        "    # hide unused axes\n",
        "    for ax in axes[len(num_cols):]:\n",
        "        ax.axis(\"off\")\n",
        "\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "\n",
        "# ----------------------------\n",
        "# 4) Run plots ONLY for filtered categorical + filtered numeric\n",
        "# ----------------------------\n",
        "\n",
        "for cat in important_cat:\n",
        "    plot_numeric_by_categorical(crd_dta_org, cat, important_num, max_levels=15, ncols=3)"
