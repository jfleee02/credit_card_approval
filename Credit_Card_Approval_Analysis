        "def plot_confusion_matrix_binary(\n",
        "    model,\n",
        "    X_test,\n",
        "    y_test,\n",
        "    labels=(0, 1),\n",
        "    class_names=None,\n",
        "    title=\"Confusion Matrix\",\n",
        "    normalize=True,\n",
        "    save_path=None,\n",
        "    threshold=None\n",
        "):\n",
        "    \"\"\"\n",
        "    Generate a report-ready binary confusion matrix.\n",
        "\n",
        "    NEW FEATURE:\n",
        "        If threshold is provided, predictions are made using:\n",
        "            prob >= threshold\n",
        "        Otherwise uses model.predict().\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    threshold : float or None\n",
        "        Custom classification threshold.\n",
        "    \"\"\"\n",
        "\n",
        "    # -------------------------\n",
        "    # Predictions\n",
        "    # -------------------------\n",
        "    if threshold is None:\n",
        "        # Default model behavior\n",
        "        y_pred = model.predict(X_test)\n",
        "\n",
        "    else:\n",
        "        # Use probabilities/scores for thresholding\n",
        "        if hasattr(model, \"predict_proba\"):\n",
        "            scores = model.predict_proba(X_test)[:, 1]\n",
        "        elif hasattr(model, \"decision_function\"):\n",
        "            scores = model.decision_function(X_test)\n",
        "        else:\n",
        "            raise ValueError(\n",
        "                \"Model must support predict_proba or decision_function \"\n",
        "                \"to use a custom threshold.\"\n",
        "            )\n",
        "\n",
        "        y_pred = (scores >= threshold).astype(int)\n",
        "\n",
        "    # -------------------------\n",
        "    # Confusion matrix\n",
        "    # -------------------------\n",
        "    cm = confusion_matrix(y_test, y_pred, labels=labels)\n",
        "\n",
        "    if normalize:\n",
        "        cm_percent = cm / cm.sum(axis=1, keepdims=True)\n",
        "    else:\n",
        "        cm_percent = None\n",
        "\n",
        "    # -------------------------\n",
        "    # Plot\n",
        "    # -------------------------\n",
        "    fig, ax = plt.subplots(figsize=(7, 6))\n",
        "    ax.imshow(cm, cmap='Blues')\n",
        "\n",
        "    ax.set_xlabel(\"Predicted Label\", fontsize=12)\n",
        "    ax.set_ylabel(\"Actual Label\", fontsize=12)\n",
        "    ax.set_title(title, fontsize=14, pad=15)\n",
        "\n",
        "    if threshold is not None:\n",
        "        title += f\" (threshold={threshold:.2f})\"\n",
        "\n",
        "    ax.set_xticks([0, 1])\n",
        "    ax.set_yticks([0, 1])\n",
        "    ax.set_xticklabels(class_names)\n",
        "    ax.set_yticklabels(class_names)\n",
        "\n",
        "    cell_labels = [[\"TN\", \"FP\"],\n",
        "                   [\"FN\", \"TP\"]]\n",
        "\n",
        "    for i in range(2):\n",
        "        for j in range(2):\n",
        "            count = cm[i, j]\n",
        "\n",
        "            if normalize:\n",
        "                percent = cm_percent[i, j] * 100\n",
        "                text = f\"{cell_labels[i][j]}\\n{count}\\n({percent:.1f}%)\"\n",
        "            else:\n",
        "                text = f\"{cell_labels[i][j]}\\n{count}\"\n",
        "\n",
        "            ax.text(j, i, text,\n",
        "                    ha=\"center\", va=\"center\",\n",
        "                    fontsize=12)\n",
        "\n",
        "    ax.set_ylim(1.5, -0.5)\n",
        "    plt.tight_layout()\n",
        "\n",
        "    if save_path:\n",
        "        plt.savefig(save_path, dpi=300, bbox_inches=\"tight\")\n",
        "\n",
        "    plt.show()\n",
        "\n",
        "    return cm"
      ],
