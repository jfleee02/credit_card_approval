        "This section outlines structured next steps to further evaluate, interpret, validate, and stress-test the final predictive and explanatory models (Random Forest and LASSO Logistic Regression).\n",
        "\n",
        "---\n",
        "\n",
        "## 1. Segment-Level Performance Analysis\n",
        "\n",
        "### Objective\n",
        "Evaluate whether model performance differs across subgroups such as:\n",
        "- Bank vs Non-Bank customers\n",
        "- Industry categories\n",
        "- Credit score tiers\n",
        "- Demographic groups\n",
        "\n",
        "This helps determine if certain populations are systematically treated differently by the model.\n",
        "\n",
        "---\n",
        "\n",
        "### Compute Performance by Segment\n",
        "\n",
        "```python\n",
        "import pandas as pd\n",
        "from sklearn.metrics import precision_score, recall_score, f1_score, confusion_matrix\n",
        "\n",
        "# Generate predictions using tuned threshold\n",
        "test_scores = _get_scores(best_rf, X_test)\n",
        "y_hat = (test_scores >= best_thr_rf).astype(int)\n",
        "\n",
        "results = pd.DataFrame({\n",
        "    \"y_true\": (y_test == 1).astype(int),\n",
        "    \"y_pred\": y_hat,\n",
        "    \"score\": test_scores,\n",
        "    \"BankCustomer\": df.loc[X_test.index, \"BankCustomer\"],   # adjust column name\n",
        "    \"Industry\": df.loc[X_test.index, \"Industry\"]\n",
        "})\n",
        "\n",
        "def metrics_by_group(g):\n",
        "    yt, yp = g[\"y_true\"], g[\"y_pred\"]\n",
        "    tn, fp, fn, tp = confusion_matrix(yt, yp, labels=[0,1]).ravel()\n",
        "    return pd.Series({\n",
        "        \"n\": len(g),\n",
        "        \"precision\": precision_score(yt, yp, zero_division=0),\n",
        "        \"recall\": recall_score(yt, yp),\n",
        "        \"f1\": f1_score(yt, yp),\n",
        "        \"selection_rate\": yp.mean(),\n",
        "        \"TPR\": tp / (tp + fn + 1e-9),\n",
        "        \"FPR\": fp / (fp + tn + 1e-9)\n",
        "    })\n",
        "\n",
        "results.groupby(\"BankCustomer\").apply(metrics_by_group)\n",
        "```\n",
        "\n",
        "---\n",
        "\n",
        "## 2. Model Explainability (Random Forest / XGBoost)\n",
        "\n",
        "### A. SHAP Global & Local Explanations\n",
        "\n",
        "```python\n",
        "import shap\n",
        "\n",
        "rf_model = best_rf.named_steps[\"model\"]\n",
        "\n",
        "background = X_train.sample(min(500, len(X_train)), random_state=42)\n",
        "explainer = shap.TreeExplainer(rf_model, data=background)\n",
        "\n",
        "shap_values = explainer.shap_values(X_test)\n",
        "\n",
        "if isinstance(shap_values, list):\n",
        "    shap_pos = shap_values[1]\n",
        "else:\n",
        "    shap_pos = shap_values\n",
        "\n",
        "shap.summary_plot(shap_pos, X_test)\n",
        "```\n",
        "\n",
        "### B. Permutation Importance\n",
        "\n",
        "```python\n",
        "from sklearn.inspection import permutation_importance\n",
        "\n",
        "perm = permutation_importance(\n",
        "    best_rf,\n",
        "    X_test,\n",
        "    y_test,\n",
        "    scoring=\"roc_auc\",\n",
        "    n_repeats=10,\n",
        "    random_state=42,\n",
        "    n_jobs=-1\n",
        ")\n",
        "\n",
        "importance = pd.Series(\n",
        "    perm.importances_mean,\n",
        "    index=X_test.columns\n",
        ").sort_values(ascending=False)\n",
        "\n",
        "importance.head(15)\n",
        "```\n",
        "\n",
        "---\n",
        "\n",
        "## 3. Fairness Assessment\n",
        "\n",
        "### Objective\n",
        "Evaluate whether model outcomes differ across demographic groups.\n",
        "\n",
        "---\n",
        "\n",
        "### Fairness Metrics by Group\n",
        "\n",
        "```python\n",
        "from fairlearn.metrics import MetricFrame, selection_rate, true_positive_rate, false_positive_rate\n",
        "from sklearn.metrics import accuracy_score\n",
        "\n",
        "mf = MetricFrame(\n",
        "    metrics={\n",
        "        \"accuracy\": accuracy_score,\n",
        "        \"selection_rate\": selection_rate,\n",
        "        \"TPR\": true_positive_rate,\n",
        "        \"FPR\": false_positive_rate\n",
        "    },\n",
        "    y_true=results[\"y_true\"],\n",
        "    y_pred=results[\"y_pred\"],\n",
        "    sensitive_features=results[\"Ethnicity\"]   # adjust column\n",
        ")\n",
        "\n",
        "mf.by_group\n",
        "```\n",
        "\n",
        "---\n",
        "\n",
        "## 4. Probability Calibration\n",
        "\n",
        "### Objective\n",
        "Evaluate whether predicted probabilities reflect actual likelihood of approval.\n",
        "\n",
        "---\n",
        "\n",
        "### Calibration Curve\n",
        "\n",
        "```python\n",
        "from sklearn.calibration import calibration_curve\n",
        "from sklearn.metrics import brier_score_loss\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "probs = best_rf.predict_proba(X_test)[:, 1]\n",
        "\n",
        "frac_pos, mean_pred = calibration_curve(\n",
        "    (y_test == 1).astype(int),\n",
        "    probs,\n",
        "    n_bins=10\n",
        ")\n",
        "\n",
        "plt.plot(mean_pred, frac_pos, marker=\"o\")\n",
        "plt.plot([0,1],[0,1], linestyle=\"--\")\n",
        "plt.xlabel(\"Mean Predicted Probability\")\n",
        "plt.ylabel(\"Fraction of Positives\")\n",
        "plt.title(\"Calibration Curve - Random Forest\")\n",
        "plt.show()\n",
        "\n",
        "print(\"Brier Score:\", brier_score_loss((y_test==1).astype(int), probs))\n",
        "```\n",
        "\n",
