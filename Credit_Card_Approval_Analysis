      "source": [
        "**RBF SVM**\n",
        "- captures non-linear relationships"
      ],
      "metadata": {
        "id": "GNiuU8o8WY4N"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# initialize the pipeline\n",
        "svm_rbf = Pipeline([\n",
        "    (\"scaler\", StandardScaler()),\n",
        "    (\"model\", SVC(kernel=\"rbf\", probability=False, random_state=42))\n",
        "])\n",
        "\n",
        "# random search metrics\n",
        "param_dist_rbf = {\n",
        "    # C controls regularization: small -> smoother; large -> more complex\n",
        "    \"model__C\": np.logspace(-2, 2, 10),\n",
        "\n",
        "    # gamma controls curve complexity:\n",
        "    # small gamma = smoother boundary (more general)\n",
        "    # large gamma = more complex boundary (risk overfit)\n",
        "    \"model__gamma\": np.logspace(-3, 0, 10),\n",
        "\n",
        "    \"model__class_weight\": [None, \"balanced\"]\n",
        "}\n",
        "\n",
        "# random search\n",
        "search_rbf = RandomizedSearchCV(\n",
        "    estimator=svm_rbf,\n",
        "    param_distributions=param_dist_rbf,\n",
        "    n_iter=20,\n",
        "    scoring=\"roc_auc\",\n",
        "    cv=5,\n",
        "    n_jobs=-1,\n",
        "    random_state=42,\n",
        "    verbose=1\n",
        ")\n",
        "\n",
        "# best model\n",
        "search_rbf.fit(X_train, y_train)\n",
        "best_svm_rbf = search_rbf.best_estimator_\n",
        "print(\"Best Params:\", search_rbf.best_params_)\n",
        "print(\"Best CV ROC-AUC:\", search_rbf.best_score_)"
      ],
