      "source": [
        "# initialize ridge pipeline (optimizing L2 penalty for ROC-AUC)\n",
        "ridge_log_reg = Pipeline([\n",
        "    ('scaler', StandardScaler()),\n",
        "    ('model', LogisticRegressionCV(\n",
        "        penalty='l2',\n",
        "        solver='lbfgs',     # best solver for L2\n",
        "        cv=5,\n",
        "        scoring='roc_auc',\n",
        "        max_iter=5000\n",
        "    ))\n",
        "])\n",
        "\n",
        "# fit the model\n",
        "ridge_log_reg.fit(X_logreg_train, y_train)\n",
        "\n",
        "# getting coefficients\n",
        "coeffs = ridge_log_reg.named_steps['model'].coef_[0]\n",
        "features = X_logreg_train.columns\n",
        "\n",
        "# dataframe of coefficients\n",
        "ridge_coeffs = pd.DataFrame({\n",
        "    \"Feature\": features,\n",
        "    \"Coefficient\": coeffs,\n",
        "    'Abs Coeff': abs(coeffs)\n",
        "}).sort_values(\"Abs Coeff\", ascending=False)\n",
        "\n",
