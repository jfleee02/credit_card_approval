<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Credit Card Approval Prediction</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #F7F5F0;
      --ink: #1A1714;
      --muted: #6B6560;
      --accent: #2A6049;
      --accent2: #3B6EA5;
      --accent3: #C94F2C;
      --rule: #D9D4CC;
      --card-bg: #FFFFFF;
      --tag-bg: #EDE9E3;
      --serif: 'DM Serif Display', Georgia, serif;
      --sans: 'DM Sans', sans-serif;
      --mono: 'DM Mono', monospace;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--ink);
      font-family: var(--sans);
      font-size: 16px;
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    /* ── NAV ── */
    nav {
      position: sticky; top: 0; z-index: 100;
      background: rgba(247,245,240,0.92);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--rule);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 clamp(1.5rem, 5vw, 4rem);
      height: 56px;
    }
    .nav-logo { font-family: var(--mono); font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); }
    .nav-links { display: flex; gap: 2rem; }
    .nav-links a { font-size: 0.82rem; font-weight: 500; letter-spacing: 0.04em; color: var(--muted); text-decoration: none; transition: color 0.2s; }
    .nav-links a:hover { color: var(--ink); }

    /* ── HERO ── */
    .hero {
      max-width: 900px; margin: 0 auto;
      padding: clamp(5rem,12vw,9rem) clamp(1.5rem,5vw,4rem) clamp(3rem,6vw,5rem);
    }
    .hero-eyebrow { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem; }
    .eyebrow-line { width: 32px; height: 1px; background: var(--accent); }
    .eyebrow-text { font-family: var(--mono); font-size: 0.75rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); }
    .hero h1 { font-family: var(--serif); font-size: clamp(2.6rem,6vw,4.5rem); line-height: 1.1; letter-spacing: -0.01em; margin-bottom: 1rem; }
    .hero h1 em { font-style: italic; color: var(--accent); }
    .hero-sub { font-size: 1.1rem; color: var(--muted); font-weight: 300; max-width: 600px; margin-bottom: 2.5rem; line-height: 1.65; }
    .hero-meta { display: flex; flex-wrap: wrap; gap: 1rem 2rem; margin-bottom: 2.5rem; padding-top: 1.5rem; border-top: 1px solid var(--rule); }
    .meta-item { display: flex; flex-direction: column; gap: 0.2rem; }
    .meta-label { font-family: var(--mono); font-size: 0.68rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); }
    .meta-value { font-size: 0.9rem; font-weight: 500; color: var(--ink); }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
    .btn { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.65rem 1.4rem; font-size: 0.85rem; font-weight: 600; font-family: var(--sans); letter-spacing: 0.02em; text-decoration: none; border-radius: 4px; transition: all 0.2s; cursor: pointer; border: none; }
    .btn-primary { background: var(--ink); color: var(--bg); }
    .btn-primary:hover { background: var(--accent); }
    .btn-outline { background: transparent; color: var(--ink); border: 1.5px solid var(--rule); }
    .btn-outline:hover { border-color: var(--ink); }

    /* ── LAYOUT ── */
    .divider { max-width: 900px; margin: 0 auto; padding: 0 clamp(1.5rem,5vw,4rem); }
    .divider hr { border: none; border-top: 1px solid var(--rule); }
    section { max-width: 900px; margin: 0 auto; padding: clamp(3rem,6vw,5rem) clamp(1.5rem,5vw,4rem); }
    .section-header { display: flex; align-items: baseline; gap: 1rem; margin-bottom: 2rem; }
    .section-num { font-family: var(--mono); font-size: 0.72rem; color: var(--muted); letter-spacing: 0.1em; }
    .section-title { font-family: var(--serif); font-size: clamp(1.6rem,3vw,2.1rem); line-height: 1.2; }

    /* ── ABSTRACT ── */
    .abstract-box { background: var(--card-bg); border: 1px solid var(--rule); border-left: 3px solid var(--accent); padding: 2rem 2.5rem; border-radius: 0 6px 6px 0; }
    .abstract-box p { font-size: 0.97rem; line-height: 1.8; }
    .abstract-box strong { color: var(--accent); font-weight: 600; }

    /* ── STATS ── */
    .stats-row { display: grid; grid-template-columns: repeat(auto-fit,minmax(150px,1fr)); gap: 1px; background: var(--rule); border: 1px solid var(--rule); border-radius: 8px; overflow: hidden; margin: 2.5rem 0; }
    .stat-cell { background: var(--card-bg); padding: 1.6rem 1.5rem; text-align: center; }
    .stat-number { font-family: var(--serif); font-size: 2rem; line-height: 1; margin-bottom: 0.4rem; }
    .stat-number.green { color: var(--accent); }
    .stat-number.blue { color: var(--accent2); }
    .stat-number.red { color: var(--accent3); }
    .stat-desc { font-size: 0.78rem; color: var(--muted); line-height: 1.4; }

    /* ── PIPELINE ── */
    .pipeline { display: flex; align-items: center; flex-wrap: wrap; gap: 0; margin: 1.5rem 0; }
    .pipe-step { background: var(--card-bg); border: 1px solid var(--rule); border-radius: 6px; padding: 0.85rem 1.2rem; font-size: 0.82rem; font-weight: 500; white-space: nowrap; }
    .pipe-step.active { background: var(--accent); color: white; border-color: var(--accent); }
    .pipe-arrow { color: var(--muted); font-size: 0.85rem; padding: 0 0.4rem; }

    /* ── METHODS GRID ── */
    .methods-grid { display: grid; grid-template-columns: repeat(auto-fit,minmax(240px,1fr)); gap: 1.25rem; margin-top: 1.5rem; }
    .method-card { background: var(--card-bg); border: 1px solid var(--rule); border-radius: 8px; padding: 1.5rem; transition: border-color 0.2s, box-shadow 0.2s; }
    .method-card:hover { border-color: var(--accent); box-shadow: 0 4px 20px rgba(42,96,73,0.08); }
    .method-icon { font-size: 1.5rem; margin-bottom: 0.75rem; }
    .method-name { font-family: var(--serif); font-size: 1.05rem; margin-bottom: 0.5rem; }
    .method-desc { font-size: 0.85rem; color: var(--muted); line-height: 1.6; }

    /* ── FINDINGS ── */
    .findings-list { display: flex; flex-direction: column; gap: 1.25rem; margin-top: 1.5rem; }
    .finding-item { display: grid; grid-template-columns: auto 1fr; gap: 1.25rem; align-items: start; padding: 1.5rem; background: var(--card-bg); border: 1px solid var(--rule); border-radius: 8px; }
    .finding-tag { font-family: var(--mono); font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; background: var(--tag-bg); color: var(--muted); padding: 0.3rem 0.65rem; border-radius: 3px; white-space: nowrap; }
    .finding-tag.green { background: rgba(42,96,73,0.1); color: var(--accent); }
    .finding-tag.blue { background: rgba(59,110,165,0.1); color: var(--accent2); }
    .finding-tag.red { background: rgba(201,79,44,0.1); color: var(--accent3); }
    .finding-text { font-size: 0.95rem; line-height: 1.65; }
    .finding-text strong { font-weight: 600; }
    .hl { font-family: var(--serif); font-size: 1.05rem; color: var(--accent); }

    /* ── TABLE ── */
    .table-wrap { overflow-x: auto; margin-top: 1.5rem; border: 1px solid var(--rule); border-radius: 8px; }
    table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    th { background: var(--tag-bg); font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); padding: 0.85rem 1.25rem; text-align: left; font-weight: 500; }
    td { padding: 0.8rem 1.25rem; border-top: 1px solid var(--rule); color: var(--ink); }
    tr:hover td { background: rgba(0,0,0,0.015); }
    .td-green { color: var(--accent); font-weight: 600; }
    .td-mono { font-family: var(--mono); font-size: 0.82rem; }
    .badge { display: inline-block; font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.08em; padding: 0.2rem 0.5rem; border-radius: 3px; font-weight: 500; }
    .badge-best { background: rgba(42,96,73,0.12); color: var(--accent); }
    .badge-good { background: rgba(59,110,165,0.1); color: var(--accent2); }
    .badge-weak { background: rgba(201,79,44,0.08); color: var(--accent3); }

    /* ── INSIGHT BOX ── */
    .insight-box { background: var(--card-bg); border: 1px solid var(--rule); border-left: 3px solid var(--accent2); padding: 1.5rem 2rem; border-radius: 0 6px 6px 0; margin-top: 2rem; }
    .insight-box h4 { font-family: var(--serif); font-size: 1rem; margin-bottom: 0.5rem; }
    .insight-box p { font-size: 0.9rem; color: var(--muted); line-height: 1.7; }
    .insight-box strong { color: var(--ink); }

    /* ── TAGS ── */
    .tags-row { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1.5rem; }
    .tech-tag { font-family: var(--mono); font-size: 0.78rem; padding: 0.4rem 0.85rem; border-radius: 4px; background: var(--tag-bg); color: var(--ink); border: 1px solid var(--rule); }
    .tech-tag.primary { background: var(--ink); color: var(--bg); border-color: var(--ink); }

    /* ── TEAM ── */
    .team-row { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem; }
    .team-member { display: flex; align-items: center; gap: 0.6rem; padding: 0.55rem 1rem; background: var(--card-bg); border: 1px solid var(--rule); border-radius: 100px; font-size: 0.85rem; }
    .team-avatar { width: 26px; height: 26px; border-radius: 50%; background: var(--tag-bg); display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 600; color: var(--muted); }

    /* ── FOOTER ── */
    footer { border-top: 1px solid var(--rule); max-width: 900px; margin: 0 auto; padding: 2.5rem clamp(1.5rem,5vw,4rem); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }
    .footer-left { font-family: var(--mono); font-size: 0.75rem; color: var(--muted); }
    .footer-right { display: flex; gap: 1.5rem; }
    .footer-right a { font-size: 0.82rem; color: var(--muted); text-decoration: none; }
    .footer-right a:hover { color: var(--ink); }

    /* ── ANIMATIONS ── */
    @keyframes fadeUp { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: translateY(0); } }
    .hero h1 { animation: fadeUp 0.7s ease both; }
    .hero-sub { animation: fadeUp 0.7s 0.1s ease both; }
    .hero-meta { animation: fadeUp 0.7s 0.2s ease both; }
    .hero-actions { animation: fadeUp 0.7s 0.3s ease both; }

    @media (max-width: 600px) {
      .nav-links { display: none; }
      .finding-item { grid-template-columns: 1fr; }
      .pipeline { gap: 0.5rem; }
      .pipe-arrow { display: none; }
    }
  </style>
</head>
